# Database (matches docker-compose.yml)
DATABASE_URL=postgres://vibeverse:vibeverse@localhost:5432/vibeverse
# Production only: direct Postgres URL for drizzle migrations and backups.
# Runtime continues to use DATABASE_URL (Supabase transaction pooler on Vercel).
# DATABASE_DIRECT_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require

# Auth (required from Phase 3)
BETTER_AUTH_SECRET=             # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# Anthropic (required from Phase 7)
ANTHROPIC_API_KEY=
ANTHROPIC_FAST_MODEL=claude-haiku-4-5
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_STRONG_MODEL=claude-opus-4-8

# Voyage AI embeddings (required from Phase 6)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-4-lite

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis (optional, used from Phase 10 for multi-instance Vibe Rooms fan-out;
# unset falls back to an in-process bus — see ARCHITECTURE.md → Realtime)
# REDIS_URL=redis://localhost:6379
